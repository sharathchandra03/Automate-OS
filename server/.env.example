# =============================================================================
# AutomateOS — Express Server Environment Variables
# Copy this file to `.env` and fill in the values.
# =============================================================================

# ---------- Supabase (required) ----------
# Same URL as the frontend
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Service role key — keeps this server-only. NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------- Token encryption (required) ----------
# Run: openssl rand -hex 16
# Used to encrypt WhatsApp access tokens before storing in DB.
ENCRYPTION_KEY="your-32-char-hex-key"

# ---------- Meta / WhatsApp (required for WhatsApp features) ----------
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
# Optional: pin the Graph API version
WHATSAPP_API_VERSION="v19.0"

# ---------- Campaign queue (required for campaigns) ----------
# Upstash Redis URL — get from console.upstash.com → REST → rediss:// URL
REDIS_URL="rediss://default:your-password@your-host.upstash.io:6379"

# ---------- CORS ----------
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# ---------- Server ----------
PORT=3001

# ---------- Optional integrations ----------
OPENAI_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TELEGRAM_BOT_TOKEN=""
RESEND_API_KEY=""
