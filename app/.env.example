# =========================================================================
# AutomateOS — Environment Variables
# Copy this file to `.env.local` and fill in the values you have.
# The app boots successfully with NO env vars (mock-data mode).
# =========================================================================

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="AutomateOS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Supabase (optional — enables real persistence + auth) ----------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------- n8n (optional — enables real automation triggers) ----------
# Base URL of your n8n instance
N8N_BASE_URL="https://n8n.example.com"
# Shared secret used to sign webhook payloads (HMAC SHA-256)
N8N_WEBHOOK_SECRET=""

# Per-action webhook URLs (override globally or per-tenant in the Connect Center).
# Any value left blank falls back to mock execution in dev mode.
N8N_WEBHOOK_LEAD_QUALIFY=""
N8N_WEBHOOK_FOLLOWUP_SEND=""
N8N_WEBHOOK_CAMPAIGN_LAUNCH=""
N8N_WEBHOOK_APPOINTMENT_BOOK=""
N8N_WEBHOOK_TICKET_CREATE=""
N8N_WEBHOOK_FAQ_REPLY=""
N8N_WEBHOOK_RETARGETING_RUN=""

# ---------- AI (optional — used by AI lead qualification) ----------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ---------- Backend server ----------
# URL of your Express backend (server/ folder). In prod: your Railway/Render URL
NEXT_PUBLIC_SERVER_URL="http://localhost:3001"

# ---------- Channels ----------

# WhatsApp via Meta Embedded Signup (Option A — recommended)
# 1. Go to developers.facebook.com → Create App → Business type → Add WhatsApp product
# 2. Copy App ID (public) and App Secret (server-only) from App Settings → Basic
# 3. (Optional) Create an Embedded Signup configuration in App → WhatsApp → Embedded Signup
#    and copy its Configuration ID into NEXT_PUBLIC_META_CONFIG_ID
NEXT_PUBLIC_META_APP_ID=""        # Your Meta App ID — safe to expose publicly
NEXT_PUBLIC_META_CONFIG_ID=""     # Embedded Signup config ID (optional but recommended)
META_APP_ID=""                    # Same App ID — used by backend for token exchange
META_APP_SECRET=""                # Keep secret — never expose to client

# WhatsApp BYOC (Option B — for clients who already have a WABA)
# These are per-org and stored encrypted in Supabase. Do not set globally.
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# SMS via Twilio
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""   # your Twilio number in +1234567890 format

# Telegram Bot
# Create a bot via @BotFather on Telegram, copy the token it gives you
TELEGRAM_BOT_TOKEN=""

# Google OAuth (Calendar / Gmail integration)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Credential encryption ----------
# Used by pgcrypto to encrypt channel credentials (access_token, bot_token, twilio_auth_token).
# Must be at least 32 characters. Set this in Supabase project settings as well:
#   ALTER DATABASE postgres SET app.credential_key = '<same value>';
CREDENTIAL_KEY=change-me-32-chars-min-xxxxxxxx

# ---------- Stripe (Week 5 — Billing) ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---------- Feature flags ----------
NEXT_PUBLIC_ENABLE_DEMO_MODE="true"
