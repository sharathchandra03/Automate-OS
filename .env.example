# =============================================================================
# AutomateOS — Environment Variables
# Copy this to:
#   .env.local  (inside app/ for Next.js)
#   .env        (inside server/ for Express server)
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Meta / WhatsApp ──────────────────────────────────────────────────────────
# From: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your_meta_app_id           # also set as NEXT_PUBLIC_META_APP_ID in app/.env.local
META_APP_SECRET=your_meta_app_secret   # NEVER expose this to the client
WHATSAPP_API_VERSION=v19.0

# Your deployed server domain (used for webhooks)
WEBHOOK_BASE_URL=https://api.automateos.in

# ── Token Encryption ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16   (produces exactly 32 hex chars = 16 bytes)
# MUST be at least 32 characters
ENCRYPTION_KEY=your_32_char_random_key_here_generate_with_openssl

# ── Redis (Upstash Free Tier recommended) ────────────────────────────────────
# Get from: https://upstash.com → Create Database → REST → Connection String
# Use the rediss:// (TLS) URL from Upstash dashboard
REDIS_URL=rediss://default:your_password@your-upstash-endpoint.upstash.io:6379

# ── Express Server ───────────────────────────────────────────────────────────
PORT=3001

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,https://automateos.in

# ── Next.js → Express Bridge ─────────────────────────────────────────────────
# The URL where the Express server is reachable (from Next.js API routes)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001        # dev
# NEXT_PUBLIC_BACKEND_URL=https://api.automateos.in  # prod

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@automateos.in

# ── n8n Integration ───────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://your-n8n-instance.com/webhook
